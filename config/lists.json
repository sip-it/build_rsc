{
  "repository": {
    "owner": "sip-it",
    "name": "build_rsc",
    "release_branch": "release"
  },
  "sources": {
    "geoip_base": "https://raw.githubusercontent.com/runetfreedom/russia-blocked-geoip/release/text",
    "geosite_base": "https://raw.githubusercontent.com/runetfreedom/russia-blocked-geosite/release"
  },
  "output": {
    "combined_rsc": "rsc/community-antifilter.rsc",
    "dns_adlist": "dns/category-ads-all.txt",
    "readme": "README.md",
    "routeros_update_script": "routeros/rf-update-community.example.rsc",
    "routeros_dns_reload_script": "routeros/rf-update-dns-adlist.example.rsc",
    "routeros_setup_1d": "routeros/rf-setup-1d.example.rsc",
    "routeros_setup_7d": "routeros/rf-setup-7d.example.rsc"
  },
  "bundle": {
    "list_name": "antifilter-community",
    "geoip_categories": [
      "ru-blocked-community"
    ],
    "geosite_categories": [
      "antifilter-download-community"
    ]
  },
  "dns_adlist": {
    "category": "category-ads-all"
  },
  "self_list": {
    "enabled": true,
    "branch": "self-list",
    "path": "self-list.txt",
    "optional": true
  },
  "domain_variants": {
    "add_www_in_combined_rsc": true,
    "skip_www_for_prefixes": [
      "api",
      "cdn"
    ]
  },
  "deduplication": {
    "enabled": true,
    "priority": "community"
  }
}
