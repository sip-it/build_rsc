{
  "repository": {
    "owner": "sip-it",
    "name": "build_rsc",
    "release_branch": "release"
  },
  "sources": {
    "geoip_base": "https://raw.githubusercontent.com/runetfreedom/russia-blocked-geoip/release/text",
    "geosite_base": "https://raw.githubusercontent.com/runetfreedom/russia-blocked-geosite/release"
  },
  "output": {
    "combined_rsc": "rsc/community-antifilter.rsc",
    "routeros_script": "routeros/rf-update-community.rsc",
    "dns_adlist": "dns/category-ads-all.txt",
    "readme": "README.md"
  },
  "bundle": {
    "list_name": "antifilter-community",
    "geoip_categories": [
      "ru-blocked-community"
    ],
    "geosite_categories": [
      "antifilter-download-community"
    ]
  },
  "dns_adlist": "category-ads-all",
  "self_list": {
    "enabled": true,
    "branch": "self-list",
    "path": "self-list.txt",
    "optional": true,
    "comment_label": "self-list"
  },
  "optional_geoip_categories": {
    "enabled": false,
    "optional": true,
    "categories": [
      "cloudflare",
      "cloudfront",
      "facebook",
      "fastly",
      "google",
      "netflix",
      "telegram",
      "twitter",
      "ddos-guard",
      "yandex"
    ]
  },
  "domain_variants": {
    "add_www_in_combined_rsc": true
  },
  "deduplication": {
    "enabled": true,
    "priority": "community"
  }
}
